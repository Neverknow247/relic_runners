; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Relic Runners"
config/version="0.000.001"
run/main_scene="uid://b5kwhn0svfexu"
config/use_custom_user_dir=true
config/custom_user_dir_name="relic_runners"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

Utils="*res://singletons/utils.gd"
Events="*res://singletons/events.gd"
Sounds="*res://singletons/sounds.tscn"
Stats="*res://singletons/stats.gd"
GlobalSteam="*uid://5y571qbak8hi"
SaveAndLoad="*res://save_and_load/save_and_load.gd"
DiscordPresence="*uid://b15fh5l2jqcik"

[display]

window/size/viewport_width=3840
window/size/viewport_height=2160
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/vsync/vsync_mode=2

[editor]

naming/node_name_casing=2

[editor_plugins]

enabled=PackedStringArray("res://addons/discord-rpc-gd/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://assets/": "green",
"res://docs/": "gray",
"res://scenes/": "red",
"res://scripts/": "yellow",
"res://shaders/": "purple",
"res://tools/": "orange",
"res://ui/": "teal"
}

